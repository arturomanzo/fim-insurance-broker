# ─── Anthropic AI (obbligatorio) ───────────────────────────────────────────
# Usato dall'assistente virtuale FIMA (/api/chat)
# Ottieni la chiave su: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Resend — invio email transazionali (opzionale) ────────────────────────
# Se non impostato, i form funzionano ma le email NON vengono inviate
# (in sviluppo i dati vengono loggati in console).
# Ottieni la chiave su: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# ID dell'audience Resend per la newsletter (opzionale)
# Crea un'audience su resend.com/audiences, poi copia l'ID (es. 78261eea-…)
# Se non impostato, le iscrizioni vengono silenziosamente ignorate.
RESEND_AUDIENCE_ID=your_resend_audience_id_here

# Indirizzo email di destinazione per le richieste del sito
FIM_EMAIL=info@fimbroker.it

# Indirizzo mittente per le email automatiche (deve essere un dominio
# verificato su Resend, es. noreply@fimbroker.it)
FIM_FROM_EMAIL=FIM Insurance Broker <noreply@fimbroker.it>

# ─── WhatsApp (opzionale) ───────────────────────────────────────────────────
# Numero WhatsApp Business (formato internazionale senza '+', es. 39XXXXXXXXXX)
# Usato dal pulsante WhatsApp fisso in basso a destra nel sito.
# Default: 390212345678
NEXT_PUBLIC_WHATSAPP_NUMBER=39XXXXXXXXXX

# ─── URL pubblico del sito (opzionale) ─────────────────────────────────────
# Usato per metadata OpenGraph, sitemap.xml e schema JSON-LD.
# Default: https://www.fimbroker.it
NEXT_PUBLIC_BASE_URL=https://www.fimbroker.it
