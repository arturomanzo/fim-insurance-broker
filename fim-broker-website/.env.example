# ============================================================
# FIM Insurance Broker — Variabili d'ambiente
# Copia questo file in .env.local e compila i valori reali.
# Su Vercel: Settings → Environment Variables
# ============================================================

# ------------------------------------------------------------
# ANTHROPIC — Chatbot FIMA (obbligatorio per il chatbot)
# https://console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# RESEND — Invio email (obbligatorio per form e magic link)
# https://resend.com → API Keys
# ------------------------------------------------------------
RESEND_API_KEY=re_...

# ID dell'Audience Resend per la newsletter
# https://resend.com → Audiences → copia l'ID
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Email mittente (deve essere un dominio verificato su Resend)
FIM_FROM_EMAIL=FIM Insurance Broker <noreply@fimbroker.it>

# Email interna dove arrivano le notifiche dei form
FIM_EMAIL=info@fimbroker.it

# ------------------------------------------------------------
# AUTENTICAZIONE CLIENT — Area Cliente (magic link)
# Genera con: openssl rand -base64 32
# ------------------------------------------------------------
CLIENT_AUTH_SECRET=sostituisci-con-stringa-casuale-32-caratteri

# ------------------------------------------------------------
# AUTENTICAZIONE ADMIN — Pannello amministrazione
# Genera con: openssl rand -base64 32
# ------------------------------------------------------------
ADMIN_AUTH_SECRET=sostituisci-con-stringa-casuale-32-caratteri

# Password di accesso al pannello /admin/login
ADMIN_PASSWORD=scegli-una-password-sicura

# ------------------------------------------------------------
# CRON — Reminder rinnovi (obbligatorio per i reminder email)
# Genera con: openssl rand -base64 32
# ------------------------------------------------------------
CRON_SECRET=sostituisci-con-stringa-casuale-32-caratteri

# ------------------------------------------------------------
# GESTIONALE — Integrazione sistema gestionale esterno
# URL del gestionale (default: https://fim-gestionale-next.vercel.app)
# ------------------------------------------------------------
GESTIONALE_API_URL=https://fim-gestionale-next.vercel.app

# Secret condiviso tra website e gestionale per autenticare le richieste API
# Deve corrispondere al valore WEBSITE_API_SECRET configurato sul gestionale
# Genera con: openssl rand -base64 32
WEBSITE_API_SECRET=sostituisci-con-secret-condiviso-col-gestionale

# ------------------------------------------------------------
# SITO — URL pubblico (default: https://www.fimbroker.it)
# ------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://www.fimbroker.it

# ------------------------------------------------------------
# WHATSAPP — Numero internazionale senza + (default: 393473312330)
# ------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=393473312330
